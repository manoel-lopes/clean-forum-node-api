{
  "name": "clean-forum-node-api",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "node --env-file .env dist/main/server.js",
    "start:dev": "tsx --env-file .env.development --watch src/main/server.ts",
    "start:test": "tsx --env-file .env.test --watch src/main/server.ts",
    "build": "tsup",
    "lint": "eslint src --fix",
    "test:unit": "vitest --run --passWithNoTests --silent --reporter verbose",
    "test:unit:watch": "vitest --passWithNoTests --silent --reporter verbose",
    "test:e2e": "dotenv -e .env.test -- vitest --run --passWithNoTests --silent --reporter verbose --pool=forks --dir src/main/routes",
    "test:dir": "vitest --run --silent --reporter verbose --dir",
    "test:ci": "vitest --run --silent --coverage",
    "migrate:dev:up": "dotenv -e .env.development -- npx prisma migrate dev",
    "migrate:dev:down": "dotenv -e .env.development -- npx prisma migrate reset",
    "migrate:test:up": "dotenv -e .env.test -- npx prisma migrate dev",
    "migrate:test:down": "dotenv -e .env.test -- npx prisma migrate reset",
    "db:up": "docker-compose --env-file .env.development up --build -d"
  },
  "dependencies": {
    "@fastify/cors": "11.0.0",
    "@fastify/swagger": "9.4.2",
    "@fastify/swagger-ui": "5.2.2",
    "@prisma/client": "6.4.1",
    "bcryptjs": "3.0.2",
    "dotenv-cli": "8.0.0",
    "fastify": "5.2.1",
    "fastify-type-provider-zod": "4.0.2",
    "ioredis": "5.5.0",
    "tsx": "4.19.3",
    "uuidv7": "1.0.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "9.21.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/bcryptjs": "2.4.6",
    "@types/supertest": "6.0.2",
    "@vitest/coverage-istanbul": "3.0.7",
    "@vitest/eslint-plugin": "1.1.36",
    "eslint": "9.21.0",
    "lint-staged": "15.4.3",
    "neostandard": "0.12.1",
    "prisma": "6.4.1",
    "supertest": "7.0.0",
    "tsup": "8.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.25.0",
    "vite": "6.2.0",
    "vitest": "3.0.7"
  }
}
